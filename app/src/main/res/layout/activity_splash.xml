<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C447C">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/circle_outline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-60dp" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="20dp" />

    <!-- حاوية المحتوى الرئيسي (لتوسيط كل شيء في المنتصف) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- الأيقونة -->
        <LinearLayout
            android:id="@+id/iconWrap"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/icon_bg"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_xray"
                app:tint="#E6F1FB" />
        </LinearLayout>

        <!-- اسم التطبيق -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edge AI X-Ray"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <!-- الوصف -->
        <TextView
            android:id="@+id/tvAppDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI-powered chest X-Ray diagnosis"
            android:textSize="13sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Tag -->
        <TextView
            android:id="@+id/tvTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by MobileNetV2"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:background="@drawable/tag_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="32dp" />

        <!-- Loading Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFF" />

    </LinearLayout>

    <!-- Version (في الأسفل) -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textSize="11sp"
        android:textColor="#4DFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>